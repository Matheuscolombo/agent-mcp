# URL do projeto Supabase do metric-streamer
SUPABASE_URL=https://emfbocpmphtftqcezaib.supabase.co

# Service role key (Dashboard → Settings → API). NUNCA commitar o .env real.
SUPABASE_SERVICE_ROLE_KEY=

# Identificador gravado em agent_action_logs.actor
AGENT_ACTOR=support-agent

# Tools de escrita arriscadas (desligadas por padrão)
MCP_ENABLE_WHATSAPP_SEND=false

# Cademi (área de membros) — sem estes dois, as tools cademi_* não são registradas
# Domínio da SUA conta Cademi (ex.: https://membros.suaempresa.com.br)
CADEMI_DOMAIN=
# Chave de API da Cademi (painel admin)
CADEMI_API_KEY=
